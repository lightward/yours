<div class="landing">
  <p class="landing-tagline">Opening Google...</p>

  <%= form_with url: google_sign_in.authorization_path, method: :post, local: true, id: "native-google-sign-in", data: { turbo: false } do %>
    <%= hidden_field_tag :proceed_to, root_path, id: nil %>
    <%= button_tag "Continue with Google", name: nil %>
  <% end %>
</div>

<script>
  document.getElementById("native-google-sign-in").requestSubmit();
</script>
