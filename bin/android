#!/usr/bin/env bash
# The Android development loop, terminal-first (no Android Studio):
#
#   bin/android build              # assemble the debug APK
#   bin/android test               # run the JVM unit tests
#   bin/android emulator           # create (if needed) and boot the emulator
#   bin/android run [args...]      # build, install, launch (args become
#                                  #   intent extras, e.g. YoursMockChat)
#   bin/android screenshot [path]  # screenshot the running emulator
#
# Useful run args (debug builds only):
#   YoursMockChat        canned day-3 conversation, no backend needed
#   YoursMockLanding     the landing screen
#   YoursMockAutoSend    with MockChat: auto-sends a message (streaming demo)
#   YoursMockSleep       with MockChat: goes straight to the night
#   YoursToken=<token>   real bearer token (mint via bin/rails runner)
#   YoursBaseURL=<url>   override backend (default http://localhost:3000,
#                        tunneled to the host machine via adb reverse)
#
# Against a real local backend: bin/dev in one terminal, then bin/android run.

set -euo pipefail
SELF="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
cd "$(dirname "$0")/../android"

export JAVA_HOME="${JAVA_HOME:-/opt/homebrew/opt/openjdk@21}"
export ANDROID_HOME="${ANDROID_HOME:-/opt/homebrew/share/android-commandlinetools}"
ADB="$ANDROID_HOME/platform-tools/adb"
BUNDLE_ID="fyi.yours.app"
AVD_NAME="yours-dev"

ensure_avd() {
  if ! "$ANDROID_HOME/cmdline-tools/latest/bin/avdmanager" list avd -c 2>/dev/null | grep -q "^$AVD_NAME$"; then
    echo "no" | "$ANDROID_HOME/cmdline-tools/latest/bin/avdmanager" create avd \
      --name "$AVD_NAME" \
      --package "system-images;android-35;google_apis;arm64-v8a" \
      --device "pixel_8" >/dev/null
  fi
}

boot_emulator() {
  if ! "$ADB" devices | grep -q "emulator-.*device$"; then
    ensure_avd
    nohup "$ANDROID_HOME/emulator/emulator" -avd "$AVD_NAME" -no-snapshot-save -no-audio \
      >/tmp/yours-emulator.log 2>&1 &
    "$ADB" wait-for-device
    # Wait for full boot
    until [ "$("$ADB" shell getprop sys.boot_completed 2>/dev/null | tr -d '\r')" = "1" ]; do
      sleep 2
    done
  fi
}

case "${1:-help}" in
  build)
    ./gradlew :app:assembleDebug --quiet
    echo "Build OK: app/build/outputs/apk/debug/app-debug.apk"
    ;;
  test)
    ./gradlew :app:testDebugUnitTest --quiet
    echo "Tests OK"
    ;;
  emulator)
    boot_emulator
    echo "Emulator ready"
    ;;
  run)
    shift || true
    ./gradlew :app:assembleDebug --quiet
    boot_emulator
    # The emulator's localhost:3000 becomes the host's localhost:3000
    "$ADB" reverse tcp:3000 tcp:3000 >/dev/null 2>&1 || true
    "$ADB" install -r app/build/outputs/apk/debug/app-debug.apk >/dev/null
    EXTRAS=""
    for arg in "$@"; do
      case "$arg" in
        *=*) EXTRAS="$EXTRAS --es ${arg%%=*} ${arg#*=}" ;;
        *) EXTRAS="$EXTRAS --ez $arg true" ;;
      esac
    done
    "$ADB" shell am force-stop "$BUNDLE_ID"
    # shellcheck disable=SC2086
    "$ADB" shell am start -n "$BUNDLE_ID/.MainActivity" $EXTRAS
    ;;
  screenshot)
    OUT="${2:-/tmp/yours-android-$(date +%H%M%S).png}"
    "$ADB" exec-out screencap -p > "$OUT"
    echo "$OUT"
    ;;
  *)
    sed -n '2,21p' "$SELF" | sed 's/^# \{0,1\}//'
    ;;
esac
