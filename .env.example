HOST=yours-dev-xyz.ngrok.lightward.dev

GOOGLE_SIGN_IN_CLIENT_ID=
GOOGLE_SIGN_IN_CLIENT_SECRET=

STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_1=
STRIPE_PRICE_ID_10=
STRIPE_PRICE_ID_100=
STRIPE_PRICE_ID_1000=

LIGHTWARD_AI_API_URL=https://lightward.com/api/stream

# Native in-app subscriptions (see PROTOCOL.md). Only needed to verify
# real App Store / Play purchases; local StoreKit testing needs none of these.
# Apple App Store Server API (App Store Connect API key):
APPLE_IAP_KEY_ID=
APPLE_IAP_ISSUER_ID=
APPLE_IAP_PRIVATE_KEY=
APPLE_IAP_BUNDLE_ID=fyi.yours.app
APPLE_IAP_ENVIRONMENT=Production
# Google Play Developer API (service-account JSON for the androidpublisher scope):
GOOGLE_PLAY_PACKAGE_NAME=fyi.yours.app
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

FATHOM_SITE=
